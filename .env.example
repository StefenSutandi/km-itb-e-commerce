# ============================================================================
# MIDTRANS PAYMENT GATEWAY CONFIGURATION
# ============================================================================

# Midtrans Server Key (SECRET - never expose to client)
# Get this from: https://dashboard.midtrans.com/settings/config_info
MIDTRANS_SERVER_KEY=your_server_key_here

# Midtrans Client Key (Safe to expose to client)
# Get this from: https://dashboard.midtrans.com/settings/config_info
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your_client_key_here

# Midtrans Environment (sandbox or production)
# Set to true for production
MIDTRANS_IS_PRODUCTION="false"

# Application URL (for Midtrans redirect callbacks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email Configuration
EMAIL_PROVIDER="resend"
RESEND_API_KEY=""
EMAIL_FROM="orders@yourdomain.com"

# Webhook URL (where Midtrans will send payment status updates)
# Usually: https://yourdomain.com/api/payments/midtrans/webhook
MIDTRANS_WEBHOOK_URL=/api/payments/midtrans/webhook

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Application URL (for payment callbacks and redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment (development, staging, production)
NODE_ENV=development

# ============================================================================
# PAYMENT SETTINGS
# ============================================================================

# Enable mock payment for testing (bypass Midtrans)
NEXT_PUBLIC_MOCK_PAYMENT=true

# Enable real Midtrans integration
NEXT_PUBLIC_REAL_PAYMENT=false

# Auto-process orders after successful payment
AUTO_PROCESS_ORDERS=false

# Send payment confirmation emails
SEND_CONFIRMATION_EMAILS=true

# Send admin notifications on payment events
SEND_ADMIN_NOTIFICATIONS=false

# ============================================================================
# EMAIL CONFIGURATION (FOR PAYMENT NOTIFICATIONS)
# ============================================================================

# Email address to send from
EMAIL_FROM=noreply@km-itb.ac.id

# Email address for reply-to
EMAIL_REPLY_TO=support@km-itb.ac.id

# Admin notification emails (comma-separated)
ADMIN_NOTIFICATION_EMAILS=admin@km-itb.ac.id,support@km-itb.ac.id

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Note: The real value must be replaced by the developer during local setup or production deployment.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/km_itb_ecommerce?schema=public"

# ============================================================================
# AUTHENTICATION CONFIGURATION (NextAuth / Auth.js)
# ============================================================================

NEXTAUTH_SECRET="replace-with-secure-random-string"
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Enable request/response logging
LOG_REQUESTS=false

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://your_key@sentry.io/your_project

# ============================================================================
# THIRD-PARTY INTEGRATIONS (FOR FUTURE USE)
# ============================================================================

# Resend Email API Key (when implementing email notifications)
# RESEND_API_KEY=re_xxx

# SendGrid API Key (alternative email provider)
# SENDGRID_API_KEY=sg_xxx

# Stripe API Key (if implementing Stripe payments in future)
# STRIPE_SECRET_KEY=sk_xxx
# NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_xxx

# ============================================================================
# FEATURE FLAGS & FALLBACKS
# ============================================================================

# Enable mock data fallback when the database is unavailable.
# IMPORTANT: Should be "false" in production!
ENABLE_MOCK_FALLBACK="true"
